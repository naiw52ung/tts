POSTGRES_DB=legendai
POSTGRES_USER=legendai
POSTGRES_PASSWORD=change-this-db-password

SECRET_KEY=change-this-super-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=postgresql+psycopg2://legendai:change-this-db-password@postgres:5432/legendai
